{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests"
  ],
  "timezone": "Europe/Berlin",
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "enabledManagers": [
    "custom.regex",
    "docker-compose",
    "dockerfile",
    "github-actions",
    "poetry"
  ],
  "prConcurrentLimit": 3,
  "prHourlyLimit": 1,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security",
      "dependencies"
    ],
    "automerge": true,
    "automergeType": "pr"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "automergeType": "pr",
    "schedule": [
      "before 4am on monday"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Keep the explicitly pinned Poetry CLI version current in Docker and CI",
      "fileMatch": [
        "(^|/)Dockerfile$",
        "(^|/)\\.github/workflows/.*\\.ya?ml$"
      ],
      "matchStrings": [
        "POETRY_VERSION[=:]\\s*\"?(?<currentValue>\\d+\\.\\d+\\.\\d+)\"?"
      ],
      "depNameTemplate": "poetry",
      "datasourceTemplate": "pypi"
    }
  ],
  "packageRules": [
    {
      "description": "Automerge tested lock-file maintenance only",
      "matchManagers": [
        "poetry"
      ],
      "matchUpdateTypes": [
        "lockFileMaintenance"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge tested stable Poetry patch updates after a 14 day safety delay",
      "matchManagers": [
        "poetry"
      ],
      "matchUpdateTypes": [
        "patch"
      ],
      "matchCurrentVersion": "!/^0\\./",
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Automerge tested stable Poetry minor updates after a 14 day safety delay",
      "matchManagers": [
        "poetry"
      ],
      "matchUpdateTypes": [
        "minor"
      ],
      "matchCurrentVersion": "!/^0\\./",
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Never automerge dependencies currently in a 0.x line",
      "matchManagers": [
        "poetry"
      ],
      "matchCurrentVersion": "/^0\\./",
      "automerge": false
    },
    {
      "description": "Automerge tested Docker digest updates",
      "matchManagers": [
        "docker-compose",
        "dockerfile"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Automerge tested GitHub Action SHA updates",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Never automerge major dependency changes",
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "description": "Never automerge updates from unstable pre-release channels",
      "matchCurrentVersion": "/-.+$/",
      "automerge": false
    }
  ]
}
